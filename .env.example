# MiMo STT（语音识别）
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# LLM 总结（任意 OpenAI 兼容服务）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# STT 并发线程数
STT_MAX_WORKERS=4

# STT 请求限速。MiMo 观察到约 100 requests/minute 会触发 429，这里默认留余量。
STT_REQUESTS_PER_MINUTE=90
STT_RATE_LIMIT_RETRIES=2

# Web 访问密码。配置后启用；Docker Compose 部署必须设置 AUTH_SECRET。
# AUTH_SECRET=change-this-password
